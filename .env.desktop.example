# ============================================================================
# Alinhafood Desktop — variáveis de build
# ----------------------------------------------------------------------------
# Copie para .env.desktop e preencha com os MESMOS valores do painel Coolify.
# ATENÇÃO: somente valores PÚBLICOS entram aqui. NUNCA coloque
# SUPABASE_SERVICE_ROLE_KEY, SUPABASE_JWT_SECRET ou qualquer chave privada —
# tudo neste arquivo acaba dentro do .exe distribuído aos clientes.
# ============================================================================

# Supabase (mesmos valores públicos usados no build web)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL de produção do Alinhafood — alvo do proxy do gateway
NEXT_PUBLIC_APP_URL=https://alinhafood.com.br

# Secret path das rotas admin/kds/garcom (o valor NEXT_PUBLIC_ já é inlinado
# no bundle do browser em produção, então embarcá-lo não cria exposição nova)
ADMIN_PATH_SECRET=
NEXT_PUBLIC_ADMIN_PATH_SECRET=
